  "components": {
    "schemas": {
      "LoginRequestModel": {
        "type": "object",
        "properties": {
          "userName": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterUserRequestModel": {
        "required": [
          "passwordHash",
          "roleId",
          "userName"
        ],
        "type": "object",
        "properties": {
          "userName": {
            "maxLength": 256,
            "minLength": 2,
            "type": "string"
          },
          "passwordHash": {
            "maxLength": 256,
            "minLength": 2,
            "type": "string"
          },
          "roleId": {
            "maximum": 150,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "StudentRequestModel": {
        "required": [
          "age",
          "course",
          "email",
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "name": {
            "maxLength": 256,
            "minLength": 2,
            "type": "string"
          },
          "email": {
            "maxLength": 256,
            "minLength": 0,
            "type": "string",
            "format": "email"
          },
          "age": {
            "maximum": 150,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "course": {
            "maxLength": 256,
            "minLength": 0,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "StudentUpdateRequestModel": {
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 256,
            "minLength": 2,
            "type": "string",
            "nullable": true
          },
          "email": {
            "maxLength": 256,
            "minLength": 0,
            "type": "string",
            "format": "email",
            "nullable": true
          },
          "age": {
            "maximum": 150,
            "minimum": 1,
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "course": {
            "maxLength": 256,
            "minLength": 0,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "TokenRequestModel": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
